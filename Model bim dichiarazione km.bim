            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "MESE",
            "formatString": "0",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "name": "NOME_MESE",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "NOME_MESE",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "NomeCompleto",
            "expression": [
              "",
              "IF(",
              "    ISBLANK(vw_DichiarazioneKM[Nome]) || ISBLANK(vw_DichiarazioneKM[Cognome]),",
              "    COALESCE(vw_DichiarazioneKM[Nome], vw_DichiarazioneKM[Cognome], \"Utente sconosciuto\"),",
              "    vw_DichiarazioneKM[Nome] & \" \" & vw_DichiarazioneKM[Cognome]",
              ")",
              ""
            ],
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "MeseAnno",
            "expression": [
              "",
              "FORMAT(vw_DichiarazioneKM[DATA_INIZIO], \"MMM YYYY\")",
              ""
            ],
            "sortByColumn": "SortMeseAnno",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "none",
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "SortMeseAnno",
            "isHidden": true,
            "expression": [
              "",
              "vw_DichiarazioneKM[ANNO] * 100 + vw_DichiarazioneKM[MESE]",
              ""
            ],
            "formatString": "0",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Giorno",
            "dataType": "int64",
            "isHidden": true,
            "expression": "DAY(vw_DichiarazioneKM[DATA_INIZIO])",
            "formatString": "0",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "GiornoData",
            "dataType": "string",
            "expression": "FORMAT(vw_DichiarazioneKM[DATA_INIZIO], \"ddd dd/MM\")",
            "sortByColumn": "SortGiornoData",
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "SortGiornoData",
            "dataType": "int64",
            "isHidden": true,
            "expression": [
              "vw_DichiarazioneKM[ANNO] * 10000",
              "        + vw_DichiarazioneKM[MESE] * 100",
              "        + DAY(vw_DichiarazioneKM[DATA_INIZIO])"
            ],
            "displayFolder": "Gerarchia Temporale",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Tratta",
            "dataType": "string",
            "expression": [
              "",
              "VAR PuntoInizio = vw_DichiarazioneKM[PUNTO_INIZIO]",
              "VAR PuntoFine   = vw_DichiarazioneKM[PUNTO_FINE]",
              "VAR Stato       = vw_DichiarazioneKM[STATO]",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        NOT ISBLANK(PuntoFine),",
              "            PuntoInizio & \" → \" & PuntoFine,",
              "        ISBLANK(PuntoFine) && Stato = \"INSERITO\",",
              "            PuntoInizio & \" → ⏳ in corso\",",
              "        ISBLANK(PuntoFine) && Stato = \"ANNULLATO\",",
              "            PuntoInizio & \" → ❌ annullata senza fine\",",
              "        PuntoInizio & \" → (sconosciuta)\"",
              "    )",
              ""
            ],
            "displayFolder": "Dettaglio Tratta",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "vw_DichiarazioneKM",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Origine = Sql.Database(\"sqltorello1.8e5e8f166c55.database.windows.net\", \"sgam_analisi\"),",
                "    dbo_vw_DichiarazioneKM = Origine{[Schema=\"dbo\",Item=\"vw_DichiarazioneKM\"]}[Data]",
                "in",
                "    dbo_vw_DichiarazioneKM"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "KM Totali",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        vw_DichiarazioneKM,",
              "        vw_DichiarazioneKM[KM_PERCORSI]",
              "    ),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\",",
              "    NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "KM Non Rendicontati",
            "expression": [
              "",
              "SUMX(",
              "    FILTER(",
              "        vw_DichiarazioneKM,",
              "        vw_DichiarazioneKM[KM_SCARTO] <> 0",
              "    ),",
              "    ABS(vw_DichiarazioneKM[KM_SCARTO])",
              ")",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "N° Errori Contachilometri",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    vw_DichiarazioneKM[KM_SCARTO] < 0",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "Tratte Aperte",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    ISBLANK(vw_DichiarazioneKM[DATA_FINE]),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "KM Medi per Tratta",
            "expression": [
              "",
              "DIVIDE(",
              "    [KM Totali],",
              "    CALCULATE(",
              "        COUNTROWS(vw_DichiarazioneKM),",
              "        vw_DichiarazioneKM[STATO] = \"INSERITO\",",
              "        NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              "    )",
              ")"
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "KM Totali Matrice",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        FILTER(",
              "            vw_DichiarazioneKM,",
              "            vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              "            && NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              "        ),",
              "        vw_DichiarazioneKM[KM_PERCORSI]",
              "    )",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "N° Tratte Matrice",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "N° Utenti Attivi",
            "expression": "CALCULATE(DISTINCTCOUNT(vw_DichiarazioneKM[ID_USER]), vw_DichiarazioneKM[STATO] = \"INSERITO\")",
            "formatString": "0"
          },
          {
            "name": "% Scarto",
            "expression": [
              "",
              "VAR KMTot = [KM Totali]",
              "VAR KMScarto = [KM Non Rendicontati]",
              "RETURN",
              "IF(",
              "    KMTot = 0 || ISBLANK(KMTot),",
              "    BLANK(),",
              "    DIVIDE(KMScarto, KMTot + KMScarto)",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%"
          },
          {
            "name": "Ultima Dichiarazione",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(vw_DichiarazioneKM[DATA_INIZIO]),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "General Date"
          },
          {
            "name": "KM Netti Totali",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        FILTER(",
              "            vw_DichiarazioneKM,",
              "            vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              "            && NOT ISBLANK(vw_DichiarazioneKM[KM_NETTI])",
              "        ),",
              "        vw_DichiarazioneKM[KM_NETTI]",
              "    )",
              ")"
            ],
            "formatString": "0"
          },
          {
            "name": "Note Tratta",
            "expression": [
              "IF(",
              "            ISINSCOPE(vw_DichiarazioneKM[Tratta]),",
              "            SELECTEDVALUE(vw_DichiarazioneKM[NOTE], \"(note multiple)\"),",
              "            BLANK()",
              "        )"
            ],
            "displayFolder": "📋 Dettaglio Tratta"
          },
          {
            "name": "Data Fine Tratta",
            "expression": [
              "IF(",
              "            ISINSCOPE(vw_DichiarazioneKM[Tratta]),",
              "            FORMAT(",
              "                SELECTEDVALUE(vw_DichiarazioneKM[DATA_FINE]),",
              "                \"dd/MM/yyyy\"",
              "            ),",
              "            BLANK()",
              "        )"
            ],
            "displayFolder": "📋 Dettaglio Tratta"
          },
          {
            "name": "Ha Dati",
            "expression": [
              "",
              "IF(",
              "    COUNTROWS(vw_DichiarazioneKM) > 0,",
              "    1,",
              "    BLANK()",
              ")",
              ""
            ],
            "formatString": "0"
          }
        ],
        "hierarchies": [
          {
            "name": "Gerarchia Data",
            "displayFolder": "Gerarchia Temporale",
            "levels": [
              {
                "name": "Anno",
                "ordinal": 0,
                "column": "ANNO"
              },
              {
                "name": "Mese",
                "ordinal": 1,
                "column": "MeseAnno"
              },
              {
                "name": "Giorno",
                "ordinal": 2,
                "column": "GiornoData"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
