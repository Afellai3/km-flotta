              }
            ]
          },
          {
            "name": "NOME_MESE",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "NOME_MESE",
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "208a9e97-564f-4491-b30e-aa6a96d86fb1",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "NomeCompleto",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "IF(",
              "    ISBLANK(vw_DichiarazioneKM[Nome]) || ISBLANK(vw_DichiarazioneKM[Cognome]),",
              "    COALESCE(vw_DichiarazioneKM[Nome], vw_DichiarazioneKM[Cognome], \"Utente sconosciuto\"),",
              "    vw_DichiarazioneKM[Nome] & \" \" & vw_DichiarazioneKM[Cognome]",
              ")",
              ""
            ],
            "lineageTag": "33b78d76-37d3-4a60-889e-80ee06e146ac",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "MeseAnno",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "FORMAT(vw_DichiarazioneKM[DATA_INIZIO], \"MMM YYYY\")",
              ""
            ],
            "sortByColumn": "SortMeseAnno",
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "c54f53ec-96bc-439c-a8ff-57b12e7f2250",
            "summarizeBy": "none",
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "SortMeseAnno",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              "",
              "vw_DichiarazioneKM[ANNO] * 100 + vw_DichiarazioneKM[MESE]",
              ""
            ],
            "formatString": "0",
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "c6461e44-ef80-4c3e-af3f-a9e50267f883",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Giorno",
            "dataType": "int64",
            "isHidden": true,
            "expression": "DAY(vw_DichiarazioneKM[DATA_INIZIO])",
            "formatString": "0",
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "b2b6183f-d39f-45ee-8386-d4e3a5f2cb8a",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "GiornoData",
            "dataType": "string",
            "expression": "FORMAT(vw_DichiarazioneKM[DATA_INIZIO], \"ddd dd/MM\")",
            "sortByColumn": "SortGiornoData",
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "d270b57c-7dfd-47e2-bb44-3dfa80469997",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "SortGiornoData",
            "dataType": "int64",
            "isHidden": true,
            "expression": [
              "vw_DichiarazioneKM[ANNO] * 10000",
              "        + vw_DichiarazioneKM[MESE] * 100",
              "        + DAY(vw_DichiarazioneKM[DATA_INIZIO])"
            ],
            "displayFolder": "Gerarchia Temporale",
            "lineageTag": "d36f8d7b-92f3-44c6-a0f4-daed4718a01b",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Tratta",
            "dataType": "string",
            "expression": [
              "",
              "VAR PuntoInizio = vw_DichiarazioneKM[PUNTO_INIZIO]",
              "VAR PuntoFine   = vw_DichiarazioneKM[PUNTO_FINE]",
              "VAR Stato       = vw_DichiarazioneKM[STATO]",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        NOT ISBLANK(PuntoFine),",
              "            PuntoInizio & \" → \" & PuntoFine,",
              "        ISBLANK(PuntoFine) && Stato = \"INSERITO\",",
              "            PuntoInizio & \" → ⏳ in corso\",",
              "        ISBLANK(PuntoFine) && Stato = \"ANNULLATO\",",
              "            PuntoInizio & \" → ❌ annullata senza fine\",",
              "        PuntoInizio & \" → (sconosciuta)\"",
              "    )",
              ""
            ],
            "displayFolder": "Dettaglio Tratta",
            "lineageTag": "927ee6b7-8499-44e2-ac6f-8a008465de0c",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "vw_DichiarazioneKM",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Origine = Sql.Database(\"sqltorello1.8e5e8f166c55.database.windows.net\", \"sgam_analisi\"),",
                "    dbo_vw_DichiarazioneKM = Origine{[Schema=\"dbo\",Item=\"vw_DichiarazioneKM\"]}[Data]",
                "in",
                "    dbo_vw_DichiarazioneKM"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "KM Totali",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        vw_DichiarazioneKM,",
              "        vw_DichiarazioneKM[KM_PERCORSI]",
              "    ),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\",",
              "    NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "5591e3a6-9a9a-4c18-8b9a-9c4d70810f51"
          },
          {
            "name": "KM Non Rendicontati",
            "expression": [
              "",
              "SUMX(",
              "    FILTER(",
              "        vw_DichiarazioneKM,",
              "        vw_DichiarazioneKM[KM_SCARTO] <> 0",
              "    ),",
              "    ABS(vw_DichiarazioneKM[KM_SCARTO])",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "d92bb53d-4a84-4d21-996b-2168b78a1a62"
          },
          {
            "name": "N° Errori Contachilometri",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    vw_DichiarazioneKM[KM_SCARTO] < 0",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "77843382-35e3-470b-b7f4-6c827c9f4a1a"
          },
          {
            "name": "Tratte Aperte",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    ISBLANK(vw_DichiarazioneKM[DATA_FINE]),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "899a2741-168a-4558-b700-bc42cb9be7e6"
          },
          {
            "name": "KM Medi per Tratta",
            "expression": [
              "",
              "DIVIDE(",
              "    [KM Totali],",
              "    CALCULATE(",
              "        COUNTROWS(vw_DichiarazioneKM),",
              "        vw_DichiarazioneKM[STATO] = \"INSERITO\",",
              "        NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              "    )",
              ")"
            ],
            "lineageTag": "55acae83-663f-4606-ae8d-52afb36291d1",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "KM Totali Matrice",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        FILTER(",
              "            vw_DichiarazioneKM,",
              "            vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              "            && NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])",
              "        ),",
              "        vw_DichiarazioneKM[KM_PERCORSI]",
              "    )",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "19d10919-ba60-44a0-8826-443babcb7f85"
          },
          {
            "name": "N° Tratte Matrice",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(vw_DichiarazioneKM),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "015144b6-c91e-4963-b67a-c107e8badb3f"
          },
          {
            "name": "N° Utenti Attivi",
            "expression": "CALCULATE(DISTINCTCOUNT(vw_DichiarazioneKM[ID_USER]), vw_DichiarazioneKM[STATO] = \"INSERITO\")",
            "formatString": "0",
            "lineageTag": "e9a4ca3a-0098-4939-8ec8-b9981785f068"
          },
          {
            "name": "% Scarto",
            "expression": [
              "",
              "VAR KMTot = [KM Totali]",
              "VAR KMScarto = [KM Non Rendicontati]",
              "RETURN",
              "IF(",
              "    KMTot = 0 || ISBLANK(KMTot),",
              "    BLANK(),",
              "    DIVIDE(KMScarto, KMTot + KMScarto)",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b0860b60-e8e9-4fef-88d3-d1b7ed009f0a"
          },
          {
            "name": "Ultima Dichiarazione",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(vw_DichiarazioneKM[DATA_INIZIO]),",
              "    vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              ")"
            ],
            "formatString": "General Date",
            "lineageTag": "5e10d9ed-e140-4627-9846-4c3b88d65d8f"
          },
          {
            "name": "KM Netti Totali",
            "expression": [
              "",
              "CALCULATE(",
              "    SUMX(",
              "        FILTER(",
              "            vw_DichiarazioneKM,",
              "            vw_DichiarazioneKM[STATO] = \"INSERITO\"",
              "            && NOT ISBLANK(vw_DichiarazioneKM[KM_NETTI])",
              "        ),",
              "        vw_DichiarazioneKM[KM_NETTI]",
              "    )",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "c58db713-723d-40f3-8987-ecc31ae6309c"
          },
          {
            "name": "Note Tratta",
            "expression": [
              "IF(",
              "            ISINSCOPE(vw_DichiarazioneKM[Tratta]),",
              "            SELECTEDVALUE(vw_DichiarazioneKM[NOTE], \"(note multiple)\"),",
              "            BLANK()",
              "        )"
            ],
            "displayFolder": "📋 Dettaglio Tratta",
            "lineageTag": "5a451cc4-6e1d-4835-b066-264d1a9ec977"
          },
          {
            "name": "Data Fine Tratta",
            "expression": [
              "IF(",
              "            ISINSCOPE(vw_DichiarazioneKM[Tratta]),",
              "            FORMAT(",
              "                SELECTEDVALUE(vw_DichiarazioneKM[DATA_FINE]),",
              "                \"dd/MM/yyyy\"",
              "            ),",
              "            BLANK()",
              "        )"
            ],
            "displayFolder": "📋 Dettaglio Tratta",
            "lineageTag": "7874659f-0d80-4dd6-b9ba-64e6a2bc5b92"
          },
          {
            "name": "Ha Dati",
            "expression": [
              "",
              "IF(",
              "    COUNTROWS(vw_DichiarazioneKM) > 0,",
              "    1,",
              "    BLANK()",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "7acc0292-d458-4e12-9f3d-b6b0cc255674"
          }
        ],
        "hierarchies": [
