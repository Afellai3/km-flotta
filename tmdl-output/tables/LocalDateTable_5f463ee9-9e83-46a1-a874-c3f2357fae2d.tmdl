table LocalDateTable_5f463ee9-9e83-46a1-a874-c3f2357fae2d
	isHidden
	showAsVariationsOnly

	column Date
		dataType: dateTime
		isHidden
		dataCategory: PaddedDateTableDates
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = User

	column Anno = YEAR([Date])
		dataType: int64
		isHidden
		dataCategory: Years
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation TemplateId = Year

	column NumMese = MONTH([Date])
		dataType: int64
		isHidden
		dataCategory: MonthOfYear
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation TemplateId = MonthNumber

	column Mese = FORMAT([Date], "MMMM")
		dataType: string
		isHidden
		dataCategory: Months
		summarizeBy: none
		sortByColumn: NumMese

		annotation SummarizationSetBy = User

		annotation TemplateId = Month

	column NumTrimestre = INT(([NumMese] + 2) / 3)
		dataType: int64
		isHidden
		dataCategory: QuarterOfYear
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation TemplateId = QuarterNumber

	column Trimestre = "Qtr " & [NumTrimestre]
		dataType: string
		isHidden
		dataCategory: Quarters
		summarizeBy: none
		sortByColumn: NumTrimestre

		annotation SummarizationSetBy = User

		annotation TemplateId = Quarter

	column Giorno = DAY([Date])
		dataType: int64
		isHidden
		dataCategory: DayOfMonth
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation TemplateId = Day

	hierarchy 'Gerarchia data'

		level Anno
			column: Anno

		level Trimestre
			column: Trimestre

		level Mese
			column: Mese

		level Giorno
			column: Giorno

		annotation TemplateId = DateHierarchy

	partition LocalDateTable_5f463ee9-9e83-46a1-a874-c3f2357fae2d = calculated
		mode: import
		source = Calendar(Date(Year(MIN('vw_DichiarazioneKM'[DATA_INIZIO])), 1, 1), Date(Year(MAX('vw_DichiarazioneKM'[DATA_INIZIO])), 12, 31))

	annotation __PBI_LocalDateTable = true

