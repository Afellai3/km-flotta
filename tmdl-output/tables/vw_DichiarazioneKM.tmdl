		dataType: int64
		formatString: 0
		displayFolder: KM
		summarizeBy: sum
		sourceColumn: KM_SCARTO

		annotation SummarizationSetBy = Automatic

	column KM_NETTI
		dataType: int64
		formatString: 0
		displayFolder: KM
		summarizeBy: sum
		sourceColumn: KM_NETTI

		annotation SummarizationSetBy = Automatic

	column NOTE
		dataType: string
		displayFolder: Dettaglio Tratta
		summarizeBy: none
		sourceColumn: NOTE

		annotation SummarizationSetBy = Automatic

	column STATO
		dataType: string
		summarizeBy: none
		sourceColumn: STATO

		annotation SummarizationSetBy = Automatic

	column DATA_INSERT
		dataType: dateTime
		formatString: General Date
		displayFolder: Dettaglio Tratta
		summarizeBy: none
		sourceColumn: DATA_INSERT

		variation Variazione
			isDefault
			relationship: e8e8a6f9-05b1-42ca-9635-6c08d85f7034
			defaultHierarchy: LocalDateTable_b9243c96-6d6a-4762-97e4-e1fdf355f828.'Gerarchia data'

		annotation SummarizationSetBy = Automatic

	column DATA_UPDATE
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: DATA_UPDATE

		variation Variazione
			isDefault
			relationship: 3c133064-64d2-4897-971f-09555e5a01ee
			defaultHierarchy: LocalDateTable_24902f4c-331c-4267-925a-3572b25dad05.'Gerarchia data'

		annotation SummarizationSetBy = Automatic

	column ANNO
		dataType: int64
		isHidden
		formatString: 0
		displayFolder: Gerarchia Temporale
		summarizeBy: sum
		sourceColumn: ANNO

		annotation SummarizationSetBy = Automatic

	column MESE
		dataType: int64
		isHidden
		formatString: 0
		displayFolder: Gerarchia Temporale
		summarizeBy: sum
		sourceColumn: MESE

		annotation SummarizationSetBy = Automatic

	column NOME_MESE
		dataType: string
		isHidden
		displayFolder: Gerarchia Temporale
		summarizeBy: none
		sourceColumn: NOME_MESE

		annotation SummarizationSetBy = Automatic

	column NomeCompleto =
			IF(
			    ISBLANK(vw_DichiarazioneKM[Nome]) || ISBLANK(vw_DichiarazioneKM[Cognome]),
			    COALESCE(vw_DichiarazioneKM[Nome], vw_DichiarazioneKM[Cognome], "Utente sconosciuto"),
			    vw_DichiarazioneKM[Nome] & " " & vw_DichiarazioneKM[Cognome]
			)
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MeseAnno =
			FORMAT(vw_DichiarazioneKM[DATA_INIZIO], "MMM YYYY")
		displayFolder: Gerarchia Temporale
		summarizeBy: none
		sortByColumn: SortMeseAnno

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column SortMeseAnno =
			vw_DichiarazioneKM[ANNO] * 100 + vw_DichiarazioneKM[MESE]
		isHidden
		formatString: 0
		displayFolder: Gerarchia Temporale
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Giorno = DAY(vw_DichiarazioneKM[DATA_INIZIO])
		dataType: int64
		isHidden
		formatString: 0
		displayFolder: Gerarchia Temporale
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column GiornoData = FORMAT(vw_DichiarazioneKM[DATA_INIZIO], "ddd dd/MM")
		dataType: string
		displayFolder: Gerarchia Temporale
		summarizeBy: none
		sortByColumn: SortGiornoData

		annotation SummarizationSetBy = Automatic

	column SortGiornoData =
			vw_DichiarazioneKM[ANNO] * 10000
			        + vw_DichiarazioneKM[MESE] * 100
			        + DAY(vw_DichiarazioneKM[DATA_INIZIO])
		dataType: int64
		isHidden
		displayFolder: Gerarchia Temporale
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Tratta =
			VAR PuntoInizio = vw_DichiarazioneKM[PUNTO_INIZIO]
			VAR PuntoFine   = vw_DichiarazioneKM[PUNTO_FINE]
			VAR Stato       = vw_DichiarazioneKM[STATO]
			RETURN
			    SWITCH(
			        TRUE(),
			        NOT ISBLANK(PuntoFine),
			            PuntoInizio & " → " & PuntoFine,
			        ISBLANK(PuntoFine) && Stato = "INSERITO",
			            PuntoInizio & " → ⏳ in corso",
			        ISBLANK(PuntoFine) && Stato = "ANNULLATO",
			            PuntoInizio & " → ❌ annullata senza fine",
			        PuntoInizio & " → (sconosciuta)"
			    )
		dataType: string
		displayFolder: Dettaglio Tratta
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	hierarchy 'Gerarchia Data'
		displayFolder: Gerarchia Temporale

		level Anno
			column: ANNO

		level Mese
			column: MeseAnno

		level Giorno
			column: GiornoData

	partition vw_DichiarazioneKM = m
		mode: import
		source =
				let
				    Origine = Sql.Database("sqltorello1.8e5e8f166c55.database.windows.net", "sgam_analisi"),
				    dbo_vw_DichiarazioneKM = Origine{[Schema="dbo",Item="vw_DichiarazioneKM"]}[Data]
				in
				    dbo_vw_DichiarazioneKM

	annotation PBI_ResultType = Table
