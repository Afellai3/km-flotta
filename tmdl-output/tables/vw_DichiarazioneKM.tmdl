		summarizeBy: none
		sourceColumn: DATA_FINE

		variation Variazione
			isDefault
			relationship: aef4b689-9448-4306-91cf-f349f4a1656a
			defaultHierarchy: LocalDateTable_ef80951f-2035-4adf-921c-6be6cef02011.'Gerarchia data'

