	column PUNTO_INIZIO
		dataType: string
		displayFolder: Dettaglio Tratta
		summarizeBy: none
		sourceColumn: PUNTO_INIZIO

		annotation SummarizationSetBy = Automatic

	column PUNTO_FINE
		dataType: string
		displayFolder: Dettaglio Tratta
		summarizeBy: none
		sourceColumn: PUNTO_FINE

		annotation SummarizationSetBy = Automatic

	column KM_INIZIO
