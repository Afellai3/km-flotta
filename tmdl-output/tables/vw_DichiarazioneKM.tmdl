table vw_DichiarazioneKM

	measure 'KM Totali' =
			CALCULATE(
			    SUMX(
			        vw_DichiarazioneKM,
			        vw_DichiarazioneKM[KM_PERCORSI]
			    ),
			    vw_DichiarazioneKM[STATO] = "INSERITO",
			    NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])
			)
		formatString: #,##0
		displayFolder: 📊 KPI Principali

	measure 'KM Non Rendicontati' =
			SUMX(
			    FILTER(
			        vw_DichiarazioneKM,
			        vw_DichiarazioneKM[KM_SCARTO] <> 0
			    ),
			    ABS(vw_DichiarazioneKM[KM_SCARTO])
			)
		formatString: #,##0
		displayFolder: 📊 KPI Principali

	measure 'KM Netti Totali' =
			CALCULATE(
			    SUMX(
			        FILTER(
			            vw_DichiarazioneKM,
			            vw_DichiarazioneKM[STATO] = "INSERITO"
			            && NOT ISBLANK(vw_DichiarazioneKM[KM_NETTI])
			        ),
			        vw_DichiarazioneKM[KM_NETTI]
			    )
			)
		formatString: #,##0
		displayFolder: 📊 KPI Principali

	measure '% Scarto' =
			VAR KMTot = [KM Totali]
			VAR KMScarto = [KM Non Rendicontati]
			RETURN
			    IF(
			        KMTot = 0 || ISBLANK(KMTot),
			        BLANK(),
			        DIVIDE(KMScarto, KMTot + KMScarto)
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 📊 KPI Principali

	measure 'N° Utenti Attivi' =
			CALCULATE(
			    DISTINCTCOUNT(vw_DichiarazioneKM[ID_USER]),
			    vw_DichiarazioneKM[STATO] = "INSERITO"
			)
		formatString: #,##0
		displayFolder: 📊 KPI Principali

	measure 'N° Tratte Totali' =
			CALCULATE(
			    COUNTROWS(vw_DichiarazioneKM),
			    vw_DichiarazioneKM[STATO] = "INSERITO"
			)
		formatString: #,##0
		displayFolder: 📊 KPI Principali

	measure 'KM Medi per Tratta' =
			DIVIDE(
			    [KM Totali],
			    [N° Tratte Totali]
			)
		formatString: #,##0.0
		displayFolder: 📊 KPI Principali

	measure '🚨 Veicoli Critici (>20%)' =
			VAR Soglia = 0.20
			VAR TargheCritiche = 
			    FILTER(
			        VALUES(vw_DichiarazioneKM[TARGA]),
			        VAR ScartoTargaCorrente = 
			            CALCULATE(
			                [% Scarto],
			                ALLEXCEPT(vw_DichiarazioneKM, vw_DichiarazioneKM[TARGA])
			            )
			        RETURN ScartoTargaCorrente > Soglia
			    )
			RETURN
			    COUNTROWS(TargheCritiche)
		formatString: #,##0
		displayFolder: 🚨 Anomalie e Controlli

	measure '⚠️ Utenti da Verificare' =
			VAR Soglia = 0.20
			VAR UtentiProblematici = 
			    FILTER(
			        VALUES(vw_DichiarazioneKM[ID_USER]),
			        VAR ScartoUtenteCorrente = 
			            CALCULATE(
			                [% Scarto],
			                ALLEXCEPT(vw_DichiarazioneKM, vw_DichiarazioneKM[ID_USER])
			            )
			        RETURN ScartoUtenteCorrente > Soglia
			    )
			RETURN
			    COUNTROWS(UtentiProblematici)
		formatString: #,##0
		displayFolder: 🚨 Anomalie e Controlli

	measure 'N° Errori Contachilometri' =
			CALCULATE(
			    COUNTROWS(vw_DichiarazioneKM),
			    vw_DichiarazioneKM[KM_SCARTO] < 0
			)
		formatString: #,##0
		displayFolder: 🚨 Anomalie e Controlli

	measure 'Tratte Aperte' =
			CALCULATE(
			    COUNTROWS(vw_DichiarazioneKM),
			    ISBLANK(vw_DichiarazioneKM[DATA_FINE]),
			    vw_DichiarazioneKM[STATO] = "INSERITO"
			)
		formatString: #,##0
		displayFolder: 🚨 Anomalie e Controlli

	measure '% Tratte Complete' =
			VAR TratteComplete = 
			    CALCULATE(
			        COUNTROWS(vw_DichiarazioneKM),
			        NOT ISBLANK(vw_DichiarazioneKM[DATA_FINE]),
			        vw_DichiarazioneKM[STATO] = "INSERITO"
			    )
			VAR TratteTotali = [N° Tratte Totali]
			RETURN
			    DIVIDE(TratteComplete, TratteTotali)
		formatString: 0.0%
		displayFolder: 🚨 Anomalie e Controlli

	measure 'Icona Stato Scarto' =
			VAR ScartoCorrente = [% Scarto]
			RETURN
			    SWITCH(
			        TRUE(),
			        ScartoCorrente > 0.20, "🔴",
			        ScartoCorrente > 0.10, "🟡",
			        ScartoCorrente > 0, "🟢",
			        "⚪"
			    )
		displayFolder: 🚨 Anomalie e Controlli

	measure 'KM Mese Corrente' =
			VAR UltimoMeseDisponibile = 
			    CALCULATE(
			        MAX(vw_DichiarazioneKM[DATA_INIZIO]),
			        REMOVEFILTERS(vw_DichiarazioneKM[DATA_INIZIO])
			    )
			VAR MeseCorrente = MONTH(UltimoMeseDisponibile)
			VAR AnnoCorrente = YEAR(UltimoMeseDisponibile)
			RETURN
			    CALCULATE(
			        [KM Totali],
			        vw_DichiarazioneKM[MESE] = MeseCorrente,
			        vw_DichiarazioneKM[ANNO] = AnnoCorrente
			    )
		formatString: #,##0
		displayFolder: 📈 Trend Temporali

	measure 'KM Mese Precedente' =
			VAR UltimoMeseDisponibile = 
			    CALCULATE(
			        MAX(vw_DichiarazioneKM[DATA_INIZIO]),
			        REMOVEFILTERS(vw_DichiarazioneKM[DATA_INIZIO])
			    )
			VAR MesePrecedente = MONTH(EDATE(UltimoMeseDisponibile, -1))
			VAR AnnoPrecedente = YEAR(EDATE(UltimoMeseDisponibile, -1))
			RETURN
			    CALCULATE(
			        [KM Totali],
			        vw_DichiarazioneKM[MESE] = MesePrecedente,
			        vw_DichiarazioneKM[ANNO] = AnnoPrecedente
			    )
		formatString: #,##0
		displayFolder: 📈 Trend Temporali

	measure 'Δ KM vs Mese Scorso' =
			[KM Mese Corrente] - [KM Mese Precedente]
		formatString: +#,##0;-#,##0;0
		displayFolder: 📈 Trend Temporali

	measure 'Δ% KM vs Mese Scorso' =
			DIVIDE(
			    [Δ KM vs Mese Scorso],
			    [KM Mese Precedente]
			)
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: 📈 Trend Temporali

	measure 'Utenti Attivi Mese Corrente' =
			VAR UltimoMeseDisponibile = 
			    CALCULATE(
			        MAX(vw_DichiarazioneKM[DATA_INIZIO]),
			        REMOVEFILTERS(vw_DichiarazioneKM[DATA_INIZIO])
			    )
			VAR MeseCorrente = MONTH(UltimoMeseDisponibile)
			VAR AnnoCorrente = YEAR(UltimoMeseDisponibile)
			RETURN
			    CALCULATE(
			        [N° Utenti Attivi],
			        vw_DichiarazioneKM[MESE] = MeseCorrente,
			        vw_DichiarazioneKM[ANNO] = AnnoCorrente
			    )
		formatString: #,##0
		displayFolder: 📈 Trend Temporali

	measure 'Utenti Attivi Mese Precedente' =
			VAR UltimoMeseDisponibile = 
			    CALCULATE(
			        MAX(vw_DichiarazioneKM[DATA_INIZIO]),
			        REMOVEFILTERS(vw_DichiarazioneKM[DATA_INIZIO])
			    )
			VAR MesePrecedente = MONTH(EDATE(UltimoMeseDisponibile, -1))
			VAR AnnoPrecedente = YEAR(EDATE(UltimoMeseDisponibile, -1))
			RETURN
			    CALCULATE(
			        [N° Utenti Attivi],
			        vw_DichiarazioneKM[MESE] = MesePrecedente,
			        vw_DichiarazioneKM[ANNO] = AnnoPrecedente
			    )
		formatString: #,##0
		displayFolder: 📈 Trend Temporali

	measure 'Δ Utenti Attivi MoM' =
			[Utenti Attivi Mese Corrente] - [Utenti Attivi Mese Precedente]
		formatString: +#,##0;-#,##0;0
		displayFolder: 📈 Trend Temporali

	measure 'Ultima Dichiarazione' =
			CALCULATE(
			    MAX(vw_DichiarazioneKM[DATA_INIZIO]),
			    vw_DichiarazioneKM[STATO] = "INSERITO"
			)
		formatString: dd/MM/yyyy
		displayFolder: 📈 Trend Temporali

	measure 'Note Tratta' =
			IF(
			    ISINSCOPE(vw_DichiarazioneKM[Tratta]),
			    SELECTEDVALUE(vw_DichiarazioneKM[NOTE], "(note multiple)"),
			    BLANK()
			)
		displayFolder: 📋 Dettaglio Tratta

	measure 'Data Fine Tratta' =
			IF(
			    ISINSCOPE(vw_DichiarazioneKM[Tratta]),
			    FORMAT(
			        SELECTEDVALUE(vw_DichiarazioneKM[DATA_FINE]),
			        "dd/MM/yyyy"
			    ),
			    BLANK()
			)
		displayFolder: 📋 Dettaglio Tratta

	measure 'Durata Tratta (giorni)' =
			IF(
			    ISINSCOPE(vw_DichiarazioneKM[Tratta]),
			    VAR DataInizio = SELECTEDVALUE(vw_DichiarazioneKM[DATA_INIZIO])
			    VAR DataFine = SELECTEDVALUE(vw_DichiarazioneKM[DATA_FINE])
			    RETURN
			        IF(
			            NOT ISBLANK(DataFine),
			            DATEDIFF(DataInizio, DataFine, DAY),
			            BLANK()
			        ),
			    BLANK()
			)
		formatString: #,##0
		displayFolder: 📋 Dettaglio Tratta

	measure 'KM Totali Matrice' =
			CALCULATE(
			    SUMX(
			        FILTER(
			            vw_DichiarazioneKM,
			            vw_DichiarazioneKM[STATO] = "INSERITO"
			            && NOT ISBLANK(vw_DichiarazioneKM[KM_PERCORSI])
			        ),
			        vw_DichiarazioneKM[KM_PERCORSI]
			    )
			)
		formatString: #,##0
		displayFolder: 🔧 Misure Supporto

	measure 'N° Tratte Matrice' =
			CALCULATE(
			    COUNTROWS(vw_DichiarazioneKM),
			    vw_DichiarazioneKM[STATO] = "INSERITO"
			)
		formatString: #,##0
		displayFolder: 🔧 Misure Supporto

	measure 'Ha Dati' =
			IF(
			    COUNTROWS(vw_DichiarazioneKM) > 0,
			    1,
			    BLANK()
			)
		formatString: 0
		displayFolder: 🔧 Misure Supporto

	column ID
